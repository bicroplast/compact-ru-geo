{
  "input": [
    {
      "type": "v2rayGeoIPDat",
      "action": "add",
      "args": {
        "uri": "/tmp/geoip_source.dat",
        "wantedList": ["private"],
        "onlyIPType": "ipv4"
      }
    }
  ],
  "output": [
    {
      "type": "v2rayGeoIPDat",
      "action": "output",
      "args": {
        "outputDir": "/tmp/geoip_out",
        "outputName": "geoip_private.dat"
      }
    }
  ]
}
