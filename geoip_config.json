{
  "input": [
    {
      "type": "v2rayGeoIPDat",
      "action": "add",
      "args": {
        "uri": "/tmp/geoip_source.dat",
        "wantedList": ["private", "ru"],
        "onlyIPType": "ipv4"
      }
    },
    {
      "type": "text",
      "action": "add",
      "args": {
        "uri": "/tmp/cidrwhitelist.txt",
        "onlyIPType": "ipv4",
        "name": "whitelist"
      }
    }
  ],
  "output": [
    {
      "type": "v2rayGeoIPDat",
      "action": "output",
      "args": {
        "outputDir": "/tmp/geoip_out",
        "outputName": "geoip.dat"
      }
    }
  ]
}
